# StockBook 环境变量模板。复制为 .env 后填值即可:  cp .env.example .env
# .env 已被 .gitignore 忽略,不会提交;本模板只放空值,绝不含真实密钥。
# 全部可不填 —— 核心追踪器零配置即可运行,以下仅在启用 RAG / 备份时需要。

# ========== RAG 问答(Phase 2,默认关)==========
# 总开关:置 1 才启用问答(需镜像装了 RAG 依赖,见 docker-compose.yml 注释)。
STOCKBOOK_RAG_ENABLED=

# Notion integration token。获取:https://www.notion.so/my-integrations 新建 integration
# → 复制 Internal Integration Token,再把要纳入知识库的页面/数据库「分享」给它。
NOTION_TOKEN=

# Anthropic API key。获取:https://console.anthropic.com/ → API Keys。
ANTHROPIC_API_KEY=

# ========== 备份(可选)==========
# 异地/同步盘备份目录(指向 iCloud/坚果云即得离机副本);留空 = 仅容器内本地备份。
STOCKBOOK_BACKUP_DIR=
# 设了口令则异地备份加密(Fernet);留空 = 异地明文 + 告警。
STOCKBOOK_BACKUP_PASSPHRASE=

# ---------- 以下为可选项,有默认值,不填即用默认 ----------
# 每日问答次数上限(成本护栏),默认 50。
# STOCKBOOK_RAG_DAILY_LIMIT=50
# 回答模型,默认 Haiku(便宜快)。想更强可切 Opus 等。
# STOCKBOOK_RAG_MODEL=claude-haiku-4-5-20251001
# 检索返回片段数,默认 5。
# STOCKBOOK_RAG_TOP_K=5
