# Local data — your real holdings live here; never commit or delete it.
stockbook.db
*.db
# local + offsite backup snapshots of real data (incl. manifest.json)
backups/

# Secrets — Notion / Anthropic keys for RAG; never commit.
.env
.env.*

# Python
__pycache__/
*.pyc
.venv/

# IDE
.idea/

